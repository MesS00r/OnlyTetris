{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "./build.sh",
            "group": "build",
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Run OS in QEMU",
            "type": "shell",
            "command": "qemu-system-i386",
            "args": [
                "-drive",
                "format=raw,file=${workspaceFolder}/build/os_image/os_image.img",
                "-d", "cpu,int,guest_errors",
                "-D", "qemu.log"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "Build",
            "problemMatcher": []
        }
    ]
}
